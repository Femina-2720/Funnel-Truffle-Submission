    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst sevenDaysAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;\nconst seen = new Set();\nconst output = [];\n\nfor (const item of items) {\n  const article = item.json;\n  \n  // Dedup by link, guid, or title (title is safest for Google News redirects)\n  const dedupKey = article.link || article.guid || article.title;\n  if (!dedupKey || seen.has(dedupKey)) continue;\n  seen.add(dedupKey);\n\n  // Date filter: skip articles older than 7 days\n  const pubDate = article.pubDate || article.isoDate;\n  if (pubDate) {\n    const articleDate = new Date(pubDate).getTime();\n    if (!isNaN(articleDate) && articleDate < sevenDaysAgo) {\n      continue;\n    }\n  }\n\n  const summary = article.contentSnippet || article.description || article.content || \"\";\n  const needsEnrichment = summary.length < 50;\n\n  output.push({\n    title: (article.title || \"Untitled\").substring(0, 200), // cap title length\n    link: article.link || article.guid || \"\",\n    pubDate: pubDate || new Date().toISOString(),\n    summary: summary.substring(0, 1000), // cap summary length\n    needs_enrichment: needsEnrichment,\n    source: article.creator || article.author || \"Unknown\"\n  });\n\n  if (output.length >= 25) break;\n}\n\nconst insufficient = output.length < 3;\n\nreturn [{\n  json: {\n    articles: output,\n    count: output.length,\n    insufficient_data: insufficient,\n    run_date: new Date().toISOString()\n  }\n}];"
      },
