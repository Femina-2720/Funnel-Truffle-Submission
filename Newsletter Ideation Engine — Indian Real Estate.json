        "mode": "runOnceForEachItem",
        "jsCode": "const enrichedText = $json.data || \"\";\nconst originalArticle = $input.item.json;\n\n// Take first 600 chars of scraped text as the summary\nconst enrichedSummary = enrichedText\n  .replace(/\\s+/g, \" \")\n  .trim()\n  .substring(0, 600);\n\nreturn {\n  json: {\n    title: originalArticle.title,\n    link: originalArticle.link,\n    pubDate: originalArticle.pubDate,\n    summary: enrichedSummary || originalArticle.summary || \"No summary available\",\n    needs_enrichment: false,\n    source: originalArticle.source || \"Unknown\",\n    was_enriched: true\n  }\n};"
